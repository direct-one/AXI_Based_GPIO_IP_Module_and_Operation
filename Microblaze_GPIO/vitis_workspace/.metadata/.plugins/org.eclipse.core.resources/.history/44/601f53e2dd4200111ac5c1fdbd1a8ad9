#include "Watch.h"


extern uint16_t counter = 0;

typedef enum{
	MIN,
	SEC
}clock_state_t;  //struct


clock_state_t Clock;


void Watch_Init(){
	FND_init();
	counter = 0;
}

void Watch_Excute(){

		UpCounter_Run();

		uint16_t total_second = counter / 60;
		uint16 seconds = total_second % 60;
		uint16 min = total_second / 60;

		FND_SetNum((*min*100) + seconds);


}





