#include <stdint.h>
#include "xparameters.h"
#include "sleep.h"
#include "xil_printf.h"

#define GPIOA_BASE_ADDR 0x44A00000
#define GPIOB_BASE_ADDR 0x44A10000


#define GPIOA_CR (*(uint32_t *) (GPIOA_BASE_ADDR+ 0x00))
#define GPIOA_IDR (*(uint32_t *) (GPIOA_BASE_ADDR + 0x04))
#define GPIOA_ODR (*(uint32_t *) (GPIOA_BASE_ADDR + 0x08))

#define GPIOB_CR (*(uint32_t *) (GPIOB_BASE_ADDR + 0x00))
#define GPIOB_IDR (*(uint32_t *) (GPIOB_BASE_ADDR+ 0x04))
#define GPIOB_ODR (*(uint32_t *) (GPIOB_BASE_ADDR + 0x08))

#define GPIOA ((GPIO_Typedef_t *) (GPIOA_BASE_ADDR))
#define GPIOB ((GPIO_Typedef_t *)(GPIOB_BASE_ADDR))


typedef struct{
	uint32_t CR;
	uint32_t IDR;
	uint32_t ODR;
}GPIO_Typedef_t;

#define GPIO_PIN_0  0x01  //0b000000001
#define GPIO_PIN_1  0x02  //0b000000010
#define GPIO_PIN_2  0x04  //0b000000100
#define GPIO_PIN_3  0x08  //0b000001000
#define GPIO_PIN_4  0x10  //0b000010000
#define GPIO_PIN_5  0x20  //0b000100000
#define GPIO_PIN_6  0x40  //0b001000000
#define GPIO_PIN_7  0x80  //0b010000000

#define OUTPUT  1
#define INPUT  0

#define RESET  0
#define SET  1

void GPIO_SetMode(GPIO_Typedef_t *GPIOx, uint32_t GPIO_Pin, int gpio_Dir){

	if(GPIO_Dir == Ouput){
		GPIOx->CR |= GPIO_Pin;
	}
	else {
		GPIOx->CR &= ~(GPIO_Pin);
	}

}

void GPIO_WritePin(GPIO_Typedef_t* GPIOx, uint16_t pin, uint8_t bitset){
	if(bitset == SET){
		GPIOx->ODR |= pin;
	}
	else {
		GPIOx->ODR &= ~pin;
	}
}

uint8_t GPIO_ReadPin(GPIO_Typedef_t* GPIOx, uint16_t pin){
	if((GPIOx->IDR & pin) != 0){
		return 1;
	}
	else{
		return 0;
	}
}

int main()
{

	//GPIOA_CR = 0xff;
	//GPIOB_CR = 0x0f;

	GPIOA->CR = 0x0f;
	GPIOB->CR = 0xff;

	GPIO_SetMode(GPIOA, GPIO_PIN_0, OUTPUT);
	GPIO_SetMode(GPIOA, GPIO_PIN_1, OUTPUT);
	GPIO_SetMode(GPIOA, GPIO_PIN_2, OUTPUT);
	GPIO_SetMode(GPIOA, GPIO_PIN_3, OUTPUT);
	GPIO_SetMode(GPIOA, GPIO_PIN_4, INPUT);
	GPIO_SetMode(GPIOA, GPIO_PIN_5, INPUT);
	GPIO_SetMode(GPIOA, GPIO_PIN_6, INPUT);
	GPIO_SetMode(GPIOA, GPIO_PIN_7, INPUT);



		while(1)
		{
			GPIOB_ODR = 0x00;

			GPIO_WritePin(GPIOA, GPIO_PIN_0, RESET);
			GPIO_WritePin(GPIOA, GPIO_PIN_1, SET);

			//if((GPIOA_IDR & (1<<4))) {
			//		GPIOA_ODR &= ~(1<<0);
			//			}

			if(GPIO_ReadPin(GPIOA, GPIO_PIN_4)){
				//GPIOA->ODR &= ~(1<<0);
				GPIO_WritePin(GPIOA, GPIO_PIN_0, RESET);

			}
			else if(GPIO_ReadPin(GPIOA, GPIO_PIN_5)){
				//GPIOA->ODR &= ~(1<<1);
				GPIO_WritePin(GPIOA, GPIO_PIN_1, RESET);

			}

			else if(GPIO_ReadPin(GPIOA, GPIO_PIN_6)){
				//GPIOA->ODR &= ~(1<<2);
				GPIO_WritePin(GPIOA, GPIO_PIN_2, RESET);

			}

			else if(GPIO_ReadPin(GPIOA, GPIO_PIN_7)){
				//GPIOA->ODR &= ~(1<<3);
				GPIO_WritePin(GPIOA, GPIO_PIN_3, RESET);
			}

			else {
				GPIOA_ODR |= (0x0f);
			}

		}
		return 0;

}
