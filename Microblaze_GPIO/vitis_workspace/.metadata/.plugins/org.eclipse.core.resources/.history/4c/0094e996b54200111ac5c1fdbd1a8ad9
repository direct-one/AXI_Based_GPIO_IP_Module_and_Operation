#include "ap_main.h"
#include "../driver/FND/FND.h"
#include "../common/common.h"
#include "UpCounter/UpCounter.h"

void ap_init(){

	FND_init();

}

void ap_excute(){

	uint16_t counter = 0;
		uint32_t prevTimeCounter = 0;
			while(1)
			{
				if(millis() - prevTimeCounter >= 100){
					prevTimeCounter = millis();
					FND_SetNum(counter++);
				}
				FND_DispDigit();
				millis_inc();
				delay_ms(1);
			}

}

