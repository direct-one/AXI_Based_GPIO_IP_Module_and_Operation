#include "HAL/GPIO/GPIO.h"
#include "driver/FND/FND.h"
#include "common/common.h"



int main()
{
	FND_init();

	uint16_t counter = 0;
	FND_SetNum(1234);
//	uint32_t prevTimeDisP = 0;
	uint32_t prevTimeCounter = 0;
		while(1)
		{
			if(millis() - prevTimeCounter >= 100){
				prevTimeCounter = millis();
				FND_SetNum(counter++);
			}
			FND_DispDigit();
			millis_inc();
			delay_ms(1);
		}
		return 0;

}
