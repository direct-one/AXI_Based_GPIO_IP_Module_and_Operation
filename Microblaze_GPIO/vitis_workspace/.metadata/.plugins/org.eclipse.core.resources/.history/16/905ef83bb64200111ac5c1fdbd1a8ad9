#include "UpCounter.h"

	uint16_t counter = 0;

void UpCounter_Init(){
	FND_init();
	counter = 0;
}

void UpCounter_Excute(){

		static uint32_t prevTimeCounter = 0;

		if(millis() - prevTimeCounter >= 100){
				return;
		}
		prevTimeCounter = millis();
		FND_SetNum(counter++);


		FND_DispDigit();
}
