uint16_t counter = 0;

void UpCounter_Init()
{
	FND_init();
	Button_Init();
	counter = 0;
}

void UpCounter_Excute(){

	 UpCounter_Disploop();

	 //static uint8_t upCounterState = 0;

	 static upcounter_state_t upCounterState = STOP;

	 switch(upCounterState){
	 case STOP:
		 UpCounter_Stop();
		 if(Button_GetState()== PUSHED){
			 upCounterState = RUN;
		 }
		 else if(Button2_GetState() == PUSHED){
			 upCounterState = CLEAR;
		 }
		 break;
	 case RUN:
		 UpCounter_Run;
		 if(Button_GetState()== PUSHED){
		 			 upCounterState = STOP;
		 		 }

	 		 break;
	 case CLEAR:
		 UpCounter_Clear();
	 		 break;
	 default:
		 UpCounter_Stop();
	 		 break;
	 }


	 if(Button_GetState() == PUSHED){
		 if(upCounterState){
		 UpCounter_Run();
		 upCounterState = 0;
		}
		 else {
		 UpCounter_Stop();
		 upCounterState = 1;
		 }
	 }

}

void UpCounter_Disploop(){
	FND_DispDigit();
}


void UpCounter_Run()
{
	static uint32_t prevTimeCounter = 0;


	if(millis() - prevTimeCounter < 100-1){
		return;
	}
	prevTimeCounter = millis();
	FND_SetNum(counter++);
}

void UpCounter_Stop(){

	FND_SetNum(counter);
}

void UpCounter_Clear(){
	counter = 0;
	FND_SetNum(0);
}




