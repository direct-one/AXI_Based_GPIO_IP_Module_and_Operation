#include "UpCounter.h"


void UpCounter_Init(){
	FND_init();
}

void UpCounter_Excute(){

	uint16_t counter = 0;
			uint32_t prevTimeCounter = 0;
				while(1)
				{
					if(millis() - prevTimeCounter >= 100){
						prevTimeCounter = millis();
						FND_SetNum(counter++);
					}
					FND_DispDigit();
					millis_inc();
					delay_ms(1);
				}

				FND_DispDigit();
}
